# DataFlare 分布式部署环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# =============================================================================
# 数据库配置
# =============================================================================

# PostgreSQL 配置
POSTGRES_DB=dataflare
POSTGRES_USER=dataflare
POSTGRES_PASSWORD=d4t4fl4r3
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# DataFlare 配置
# =============================================================================

# 服务器配置
DATAFLARE_SERVER_URL=http://localhost:8080
DATAFLARE_WEBSERVER_PORT=8080
DATAFLARE_MANAGEMENT_PORT=8081

# 认证配置
DATAFLARE_AUTH_ENABLED=false
DATAFLARE_AUTH_USERNAME=admin@dataflare.io
DATAFLARE_AUTH_PASSWORD=dataflare

# 存储配置
DATAFLARE_STORAGE_TYPE=local
DATAFLARE_STORAGE_BASE_PATH=/app/storage

# 队列配置
DATAFLARE_QUEUE_TYPE=postgres

# Worker 配置
DATAFLARE_WORKER_THREADS=4

# =============================================================================
# 监控配置
# =============================================================================

# Prometheus 配置
PROMETHEUS_PORT=9090

# Grafana 配置
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# 网络配置
# =============================================================================

# Nginx 配置
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Redis 配置
REDIS_PORT=6379

# =============================================================================
# 安全配置
# =============================================================================

# SSL 证书路径（如果启用 HTTPS）
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# JWT 密钥（生产环境请更改）
JWT_SECRET=your-secret-key-here

# =============================================================================
# 性能配置
# =============================================================================

# JVM 配置
JAVA_OPTS=-Xmx2g -Xms1g

# 数据库连接池配置
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# =============================================================================
# 日志配置
# =============================================================================

# 日志级别
LOG_LEVEL=INFO
ROOT_LOG_LEVEL=WARN

# =============================================================================
# 开发配置
# =============================================================================

# 开发模式
DEV_MODE=false

# 热重载
HOT_RELOAD=false

# 调试端口
DEBUG_PORT=5005

# =============================================================================
# 备份配置
# =============================================================================

# 备份目录
BACKUP_DIR=./backups

# 备份保留天数
BACKUP_RETENTION_DAYS=30

# =============================================================================
# 扩展配置
# =============================================================================

# 插件目录
PLUGINS_DIR=./plugins

# 自定义配置文件路径
CUSTOM_CONFIG_PATH=./config/application.yml

# =============================================================================
# 云存储配置（可选）
# =============================================================================

# AWS S3 配置
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=dataflare-storage

# Google Cloud Storage 配置
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET=dataflare-storage
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Azure Blob Storage 配置
# AZURE_STORAGE_ACCOUNT=your-storage-account
# AZURE_STORAGE_KEY=your-storage-key
# AZURE_CONTAINER=dataflare-storage

# =============================================================================
# 通知配置（可选）
# =============================================================================

# Slack 通知
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# 邮件通知
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-password

# =============================================================================
# 高级配置
# =============================================================================

# 集群配置
CLUSTER_ENABLED=false
CLUSTER_NODE_ID=node-1

# 缓存配置
CACHE_ENABLED=true
CACHE_SIZE=1000

# 指标配置
METRICS_ENABLED=true
METRICS_PREFIX=dataflare

# 追踪配置
TRACING_ENABLED=false
JAEGER_ENDPOINT=http://jaeger:14268/api/traces
